# 虚拟环境相关文件和目录
.env
.venv/
env/               # 虚拟环境目录（另一种命名）
venv/              # 虚拟环境目录（标准命名）
ENV/               # 虚拟环境目录（大写命名）

# IDE（集成开发环境）相关文件
.idea/             # PyCharm IDE配置目录
.vscode/           # Visual Studio Code配置目录
.cursor/           # Cursor IDE配置目录
*.swp              # Vim临时文件
*.swo              # Vim临时文件（另一种格式）
.project           # Eclipse项目文件
.pydevproject      # Eclipse Python项目配置文件

# 项目特定文件
data/input/*       # 输入数据目录下的所有文件
data/output/*      # 输出数据目录下的所有文件
!data/input/.gitkeep   # 保留空的input目录
!data/output/.gitkeep  # 保留空的output目录
*.key              # 密钥文件
*.log              # 日志文件
*.spec             # PyInstaller规范文件
*.exe              # 可执行文件

# 操作系统生成的文件
.DS_Store          # macOS系统文件
Thumbs.db          # Windows缩略图缓存文件

# --- Electron / Node（M1 重构新增） ---
node_modules/
out/
app/server/.venv/
app/server/.data/
.pytest_cache/
!app/server/ai-review-backend.spec

# archive/ 为旧数据存档（logs/material/hide_file，本地保留不入库）
archive/

# electron-builder 产物（安装包与 win-unpacked，体积大）
release/


# 许可证服务器数据目录（SQLite + 私钥，不入库）
app/license-server/.data/
!app/license-server/ai-review-license-server.spec

# 许可证集成冒烟脚本的临时打包产物
scripts/.license-smoke.bundle.mjs
