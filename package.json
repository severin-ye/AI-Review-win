{
  "name": "ai-review",
  "version": "0.1.0",
  "private": true,
  "description": "AI 审校助手 — Electron + React + TypeScript + Python FastAPI sidecar",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:renderer": "vite --config app/web/vite.config.ts",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test:license": "vitest run",
    "start": "electron-vite preview",
    "backend:dev": "cd app/server && .venv\\Scripts\\python -m uvicorn app.main:app --reload --port 8765",
    "backend:setup": "cd app/server && python -m venv .venv && .venv\\Scripts\\python -m pip install -r requirements.txt",
    "dist:backend": "cd app/server && .venv\\Scripts\\python -m PyInstaller ai-review-backend.spec --noconfirm",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vitest": "^3.2.4"
  }
}
